---
# Host-specific secrets and overrides for bee (Beelink MINI-S13)
#
# This file is gitignored. Copy it from host_vars/bee.yml.example and fill in
# your secrets.
#
# Example:
# cloudflare_tunnel_token: "<paste-token-from-cloudflare-dashboard>"

# Tailscale hostname for this server
tailscale_hostname: bee
tailscale_serve_enabled: false

# Optional services (defaults to false in group_vars/all.yml)
opencode_server_install: false
deutsch_app_install: false
coolify_server_install: false
coolify_worker_install: false
cloudflare_tunnel_install: false

# Cloudflare tunnel token if this server should run a tunnel.
# Currently not used for bee; the tunnel runs on neo.
# cloudflare_tunnel_token: ""

# Keycloak bootstrap client secret if needed
# grapity_keycloak_bootstrap_client_secret: ""
