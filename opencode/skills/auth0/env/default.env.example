tenant=<auth0-tenant-base-url>
cacert=/etc/ssl/cert.pem

client_id=<management-api-client-id>
client_secret=<management-api-client-secret>
resource_server_identifier=<auth0-management-api-audience-url>

# Private key JWT flow — fill these in instead of client_secret:
# private_key_path=<absolute-path-to-private-key.pem>
# auth0_kid=<key-id-registered-in-auth0>
# auth0_client_id=<client-id-using-private-key-jwt>
# audience=<tenant-url-used-as-jwt-aud, e.g. https://auth.dev.sygnum.tech/>
